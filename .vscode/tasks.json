{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Docs: Demo-Kunde bauen",
      "type": "shell",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/build.ps1",
        "-Customer",
        "example-ag"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Docs: Demo-Kunde beobachten",
      "type": "shell",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/build.ps1",
        "-Customer",
        "example-ag",
        "-Watch"
      ],
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Docs: alle Kunden bauen",
      "type": "shell",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/build.ps1",
        "-All"
      ],
      "problemMatcher": []
    }
  ]
}

